{
  "name": "openclaw-backup",
  "version": "0.1.0",
  "description": "Open-source encrypted backup system for OpenClaw workspaces",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "openclaw-backup": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc",
    "build:web": "cd src/web && npx vite build --outDir ../../dist/web",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/api/server.ts --port 11480",
    "dev:web": "cd src/web && npx vite",
    "start": "node dist/api/server.js",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "backup",
    "openclaw",
    "encryption",
    "incremental",
    "deduplication"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "inquirer": "^9.2.0",
    "minimatch": "^10.2.4",
    "node-cron": "^3.0.3",
    "ora": "^8.0.0",
    "sodium-native": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
